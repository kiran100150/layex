\textbf{Chapter-06}\hspace{1cm}\textbf{Numbered Theorems, Definitions,
Corollaries and Lemmas}
\section*{Theorem}
\begin{theorem}
If \( a \) and \( b \) are odd integers, then their product \( a
\cdot b \) is also odd.
\end{theorem}
\section*{Definition}
\begin{definition}
A function \( f \colon X \to Y \) is called injective (or oneto-one) if for all \( x_1, x_2 \in X \), \( f(x_1) = f(x_2) \)
implies \( x_1 = x_2 \).
\end{definition}
\section*{Lemma}
\begin{lemma}
Let \( A \) and \( B \) be sets. If \( A \subseteq B \) and \( B
\subseteq C \), then \( A \subseteq C \).
\end{lemma}
\section*{Corollary}
\begin{corollary}
If \( A \subseteq B \) and \( A = B \), then \( B \subseteq A
\).
\end{corollary}
